{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Config",
  "description": "Port of opencode `ConfigV1.Info` (`config.ts:32-189`).\n\nExtra / unknown keys parse without error but are dropped on re-serialize.",
  "type": "object",
  "properties": {
    "$schema": {
      "description": "`$schema` (`config.ts:33`).",
      "type": [
        "string",
        "null"
      ]
    },
    "agent": {
      "description": "`agent` map (`config.ts:93-106`) — permissive, decoupled from `ConfigAgentV1`."
    },
    "attachment": {
      "description": "`attachment` (`config.ts:127`) — permissive."
    },
    "autoupdate": {
      "description": "`autoupdate` — `bool | \"notify\"` (`config.ts:64`), kept permissive."
    },
    "command": {
      "description": "`command` map (`config.ts:41-43`) — kept permissive.",
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": true
    },
    "compaction": {
      "description": "`compaction` (`config.ts:146`).",
      "anyOf": [
        {
          "$ref": "#/definitions/Compaction"
        },
        {
          "type": "null"
        }
      ]
    },
    "default_agent": {
      "description": "`default_agent` (`config.ts:80`).",
      "type": [
        "string",
        "null"
      ]
    },
    "disabled_providers": {
      "description": "`disabled_providers` (`config.ts:68`).",
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "string"
      }
    },
    "enabled_providers": {
      "description": "`enabled_providers` (`config.ts:71`).",
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "string"
      }
    },
    "enterprise": {
      "description": "`enterprise` (`config.ts:130`).",
      "anyOf": [
        {
          "$ref": "#/definitions/Enterprise"
        },
        {
          "type": "null"
        }
      ]
    },
    "experimental": {
      "description": "`experimental` (`config.ts:166`) — permissive."
    },
    "formatter": {
      "description": "`formatter` — `bool | Record<..>` (`config.ts:113`), permissive."
    },
    "hooks": {
      "description": "`hooks` — otto-native lifecycle hooks (external, user-configured commands fired at points in the session/tool/compaction pipeline). No opencode analogue — otto extension inspired by Claude Code's hooks.",
      "anyOf": [
        {
          "$ref": "#/definitions/HooksConfig"
        },
        {
          "type": "null"
        }
      ]
    },
    "instructions": {
      "description": "`instructions` (`config.ts:121`) — merge concatenates + dedupes these (see `loader::merge`, `mergeConfigConcatArrays` config.ts:45-51).",
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "string"
      }
    },
    "logLevel": {
      "description": "`logLevel` (`config.ts:37`).",
      "anyOf": [
        {
          "$ref": "#/definitions/LogLevel"
        },
        {
          "type": "null"
        }
      ]
    },
    "lsp": {
      "description": "`lsp` — `bool | Record<..>` (`config.ts:117`), permissive."
    },
    "mcp": {
      "description": "`mcp` map (`config.ts:110-112`) — permissive (typed schema is Phase 6)."
    },
    "model": {
      "description": "`model` as `provider/model` (`config.ts:74`).",
      "type": [
        "string",
        "null"
      ]
    },
    "permission": {
      "description": "`permission` (`config.ts:125`) — permissive; typing lives in `otto-permission`."
    },
    "permission_mode": {
      "description": "`permission_mode` — the starting per-session permission mode (`approve-each` | `accept-edits` | `full-auto`). Otto-only. Defaults to `approve-each` when absent. The mode can be cycled live in the TUI.",
      "type": [
        "string",
        "null"
      ]
    },
    "plugin": {
      "description": "`plugin` specs (`config.ts:56`).",
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "string"
      }
    },
    "provider": {
      "description": "`provider` map (`config.ts:107-109`) — permissive."
    },
    "retry": {
      "description": "`retry` — provider retry/backoff knobs (otto extension).",
      "anyOf": [
        {
          "$ref": "#/definitions/Retry"
        },
        {
          "type": "null"
        }
      ]
    },
    "rtk": {
      "description": "`rtk` — optional RTK (Rust Token Killer) shell-command wrapping. Otto-only (no opencode analogue). When enabled and `rtk` is on `PATH`, the `bash` tool's commands are routed through `rtk` to compact their output.",
      "anyOf": [
        {
          "$ref": "#/definitions/Rtk"
        },
        {
          "type": "null"
        }
      ]
    },
    "share": {
      "description": "`share` (`config.ts:57`).",
      "anyOf": [
        {
          "$ref": "#/definitions/Share"
        },
        {
          "type": "null"
        }
      ]
    },
    "shell": {
      "description": "`shell` (`config.ts:36`).",
      "type": [
        "string",
        "null"
      ]
    },
    "skills": {
      "description": "`skills` (`config.ts:44`) — kept permissive."
    },
    "small_model": {
      "description": "`small_model` (`config.ts:77`).",
      "type": [
        "string",
        "null"
      ]
    },
    "tersemode": {
      "description": "`tersemode` — optional terse-output mode. Otto-only (no opencode analogue). When enabled, a brevity directive is appended to the system prompt so the model emits fewer output tokens (drops filler/articles/hedging) while keeping code, paths, and error strings byte-exact.",
      "anyOf": [
        {
          "$ref": "#/definitions/Tersemode"
        },
        {
          "type": "null"
        }
      ]
    },
    "theme": {
      "description": "Named TUI color theme preset (e.g. \"catppuccin\", \"gruvbox\", \"nord\", \"base16\"). Unknown names fall back to the default dark theme.",
      "type": [
        "string",
        "null"
      ]
    },
    "tool_output": {
      "description": "`tool_output` (`config.ts:133`).",
      "anyOf": [
        {
          "$ref": "#/definitions/ToolOutput"
        },
        {
          "type": "null"
        }
      ]
    },
    "tools": {
      "description": "`tools` gate map (`config.ts:126`).",
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": {
        "type": "boolean"
      }
    },
    "username": {
      "description": "`username` (`config.ts:84`).",
      "type": [
        "string",
        "null"
      ]
    },
    "watcher": {
      "description": "`watcher` (`config.ts:51`).",
      "anyOf": [
        {
          "$ref": "#/definitions/Watcher"
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "definitions": {
    "Compaction": {
      "description": "`compaction` (`config.ts:146-165`).",
      "type": "object",
      "properties": {
        "auto": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "preserve_recent_tokens": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0.0
        },
        "prune": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "prune_protect_tokens": {
          "description": "Trailing tool-output token budget protected from post-turn pruning (otto extension; default 40000).",
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0.0
        },
        "reserved": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0.0
        },
        "tail_turns": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0.0
        }
      }
    },
    "Enterprise": {
      "description": "`enterprise` (`config.ts:130-132`).",
      "type": "object",
      "properties": {
        "url": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "HookCommand": {
      "description": "One external command to run via `sh -c`.",
      "type": "object",
      "required": [
        "command"
      ],
      "properties": {
        "command": {
          "type": "string"
        },
        "timeout_ms": {
          "description": "Overrides `otto_hooks::runner::DEFAULT_TIMEOUT_MS` for this command.",
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0.0
        }
      }
    },
    "HookMatcherGroup": {
      "description": "A tool-id matcher plus the commands to run when it matches (or, for non-tool events, unconditionally).",
      "type": "object",
      "required": [
        "hooks"
      ],
      "properties": {
        "hooks": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/HookCommand"
          }
        },
        "matcher": {
          "description": "Regex tested against the tool id. `None` matches every tool id, and the field is ignored entirely for non-tool events.",
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "HooksConfig": {
      "description": "One `HookMatcherGroup` list per lifecycle event otto supports.",
      "type": "object",
      "properties": {
        "notification": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/HookMatcherGroup"
          }
        },
        "post_tool_use": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/HookMatcherGroup"
          }
        },
        "pre_compact": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/HookMatcherGroup"
          }
        },
        "pre_tool_use": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/HookMatcherGroup"
          }
        },
        "session_start": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/HookMatcherGroup"
          }
        },
        "stop": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/HookMatcherGroup"
          }
        },
        "subagent_stop": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/HookMatcherGroup"
          }
        },
        "user_prompt_submit": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/HookMatcherGroup"
          }
        }
      }
    },
    "LogLevel": {
      "description": "Log verbosity — `LogLevelRef` (`config.ts:27-30`).",
      "type": "string",
      "enum": [
        "DEBUG",
        "INFO",
        "WARN",
        "ERROR"
      ]
    },
    "Retry": {
      "description": "`retry` — provider retry/backoff knobs (otto extension, no opencode analog). All fields optional; unset falls back to the session defaults (`otto-session`'s `DEFAULT_MAX_RETRIES` / `DEFAULT_MAX_TOTAL_RETRIES`).",
      "type": "object",
      "properties": {
        "max_attempts": {
          "description": "Cap on retries of one step (one provider request). Default 5.",
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "minimum": 0.0
        },
        "max_total_attempts": {
          "description": "Cap on retries summed across all steps of one prompt. Default 20.",
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "minimum": 0.0
        },
        "turn_timeout_seconds": {
          "description": "Wall-clock cap on one prompt turn, in seconds. Unset = no timeout.",
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0.0
        }
      }
    },
    "Rtk": {
      "description": "`rtk` config block. Off unless `enabled` is set.",
      "type": "object",
      "properties": {
        "enabled": {
          "description": "Route `bash` commands through the `rtk` proxy when it is available.",
          "default": false,
          "type": "boolean"
        }
      }
    },
    "Share": {
      "description": "Session sharing behavior — `share` (`config.ts:57-60`).",
      "type": "string",
      "enum": [
        "manual",
        "auto",
        "disabled"
      ]
    },
    "Tersemode": {
      "description": "`tersemode` config block. Off unless `enabled` is set; `level` defaults to [`TersemodeLevel::Full`] when omitted.",
      "type": "object",
      "properties": {
        "enabled": {
          "description": "Append the terse-output directive to the system prompt.",
          "default": false,
          "type": "boolean"
        },
        "level": {
          "description": "How aggressively to compress prose. Ignored when `enabled` is false.",
          "default": "full",
          "allOf": [
            {
              "$ref": "#/definitions/TersemodeLevel"
            }
          ]
        }
      }
    },
    "TersemodeLevel": {
      "description": "Tersemode intensity. Controls how far the brevity directive pushes the model. Serialized lowercase (`\"lite\" | \"full\" | \"ultra\" | \"wenyan\"`).",
      "oneOf": [
        {
          "description": "Drop filler/hedging, keep grammar + full sentences.",
          "type": "string",
          "enum": [
            "lite"
          ]
        },
        {
          "description": "Drop articles, fragments OK, short synonyms. The classic default.",
          "type": "string",
          "enum": [
            "full"
          ]
        },
        {
          "description": "Telegraphic: heavy abbreviation, arrows for causality, one word when one word does.",
          "type": "string",
          "enum": [
            "ultra"
          ]
        },
        {
          "description": "Classical-Chinese brevity register (文言文).",
          "type": "string",
          "enum": [
            "wenyan"
          ]
        }
      ]
    },
    "ToolOutput": {
      "description": "`tool_output` truncation thresholds (`config.ts:133-145`).",
      "type": "object",
      "properties": {
        "max_bytes": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0.0
        },
        "max_lines": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint64",
          "minimum": 0.0
        }
      }
    },
    "Watcher": {
      "description": "`watcher` (`config.ts:51`).",
      "type": "object",
      "properties": {
        "ignore": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
