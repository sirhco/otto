      "description": "Tersemode intensity. Controls how far the brevity directive pushes the model. Serialized lowercase (`\"lite\" | \"full\" | \"ultra\" | \"wenyan\"`).",
      "oneOf": [
        {
          "description": "Drop filler/hedging, keep grammar + full sentences.",
          "type": "string",
          "enum": [
            "lite"
          ]
        },
        {
          "description": "Drop articles, fragments OK, short synonyms. The classic default.",
          "type": "string",
          "enum": [
            "full"
          ]
        },
        {
          "description": "Telegraphic: heavy abbreviation, arrows for causality, one word when one word does.",
          "type": "string",
          "enum": [
            "ultra"
          ]
        },
        {
          "description": "Classical-Chinese brevity register (µ¢ćĶ©Ćµ¢ć).",
          "type": "string",
          "enum": [
            "wenyan"
          ]
        }
