      "description": "`tersemode` config block. Off unless `enabled` is set; `level` defaults to [`TersemodeLevel::Full`] when omitted.",
      "type": "object",
      "properties": {
        "enabled": {
          "description": "Append the terse-output directive to the system prompt.",
          "default": false,
          "type": "boolean"
        },
        "level": {
          "description": "How aggressively to compress prose. Ignored when `enabled` is false.",
          "default": "full",
          "allOf": [
